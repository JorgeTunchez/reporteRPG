      * -------------------------------------------------------
      * Definici�n de llaves
     C     CLIKEY        KLIST
     C                   KFLD                    CLTDOC            1
     C                   KFLD                    CLDOC
     C     EMAILK        KLIST
     C                   KFLD                    CLTDOC            1
     C                   KFLD                    CLDOC
     C                   KFLD                    CLDICO
     c     CTAKEY        kList
     c                   kfld                    TIPO
     c                   kfld                    AGEN
     c                   kfld                    CORR
     c                   kfld                    DIVE
     C     IBERKEY       KLIST
     C                   KFLD                    CANAL
     C                   KFLD                    MEAPLI
     C                   KFLD                    MECODE
     C     EXENKEY       KLIST
     C                   KFLD                    ACHRCIF
     C                   KFLD                    ACHRBCO
     C                   KFLD                    ACHRCTA
     C     LOGKEY        KLIST
     C                   KFLD                    CACODE
     C                   KFLD                    WI_KEYPXP
     C     LOGKEYJ       KLIST
     C                   KFLD                    CACODE
     C                   KFLD                    WI_KEYPXP
     C                   KFLD                    PXPCOR
      *
     C     BXITKEY       KLIST
     C                   KFLD                    CACODE
     C                   KFLD                    DI1_IDBXI
     C                   KFLD                    TIPOTR            1
     C     BXITKE2       KLIST
     C                   KFLD                    CACODE
     C                   KFLD                    DI5_IDBXI
     C                   KFLD                    TIPOTR            1
     c     DESBKEY       KLIST
     c                   KFLD                    CACODE
     c                   KFLD                    DI6_IDBXI
     c                   KFLD                    TSTIPT
      *
     C     *ENTRY        PLIST
     C                   PARM                    CANAL             2
      *
     C     CANAL         CHAIN     IBPARM01                           19

      *Recupera parametros del servidor
     C                   MoveL     ' '           EliminaDTQ        1
     C                   EXSR      REFRESCA
     C                   EXSR      TRAECOLAS
      * COMIENZA EL CICLO
     C                   Z-ADD     2             DOS               2 0
     C     1             DOWNE     DOS
     C                   CALL      'QRCVDTAQ'                           13
     C                   PARM                    DTQI             10
     C                   PARM                    PARBIQ
     C                   PARM                    LONI              5 0
     C                   PARM      *BLANKS       DATAIN         1024
     C                   PARM      IDTIMW        VALMEN            5 0
      *Si da error el QRCV crea la cola
     C                   If        *In13
     C                   MoveL     'N'           EliminaDTQ        1
     C                   Exsr      TraeColas
     C                   EndIf
      * Finaliza
     C                   if        %Trim(DATAIN) = 'ENDSERVER'
     C                   Leave
     C                   EndIf
      * Refrescar
     C                   if        %Trim(DATAIN) = 'REFRESH'
     C                   Exsr      Refresca
     C                   Iter
     C                   EndIf
      *
     C                   if        %Trim(DATAIN) <> 'REFRESH'
     C                             AND %Trim(DATAIN) <> 'ENDSERVER'
      *Procesa Debito/Credito/Ejecucion programa
     C                   EXSR      PROCE
     C                   ENDIF
      **
     C                   ENDDO
      *
     C                   MOVE      *ON           *INLR
     C                   RETURN
      *********************************************************************
      * Trae Nombre de Colas
      *********************************************************************
     C     TraeColas     BegSr

     C     IDSRK         KList
     C                   KFld                    CANAL
     C                   KFld                    IDSRV

     C                   Eval      IDSRV = 'IBDCRSIP'
     C     IDSRK         Chain     IBIDSR01                           18
     C                   If        Not *In18
     C                   If        IDCOLI = *Blanks
     C                   Eval      DTQI = 'OPESIPI'
     C                   Else
     C                   Eval      DTQI = IDCOLI
     C                   EndIf
     C                   If        IDCOLO = *Blanks
     C                   Eval      DTQO = 'OPESIPO'
     C                   Else
     C                   Eval      DTQO = IDCOLO
     C                   EndIf

     C                   If        EliminaDTQ = 'N'
     C                   Eval      IDSELI = 0
     C                   EndIf
     C                   Call      'IBCRTDTQ'
     C                   Parm                    DTQI             10
     C                   Parm      PARBIQ        BIBI             10
     C                   Parm      'I'           TIPODQ            1
     C     LONI          Parm                    IDSLDI
     C                   Parm      0             LONKDQ            3 0
     C                   Parm                    IDSELI

     C                   Call      'IBCRTDTQ'
     C                   Parm                    DTQO             10
     C                   Parm      PARBIQ        BIBI
     C                   Parm      'O'           TIPODQ
     C                   Parm                    IDSLDS
     C                   Parm      IDSLKY        LONKDQ            3 0
     C                   Parm                    IDSELI
     C                   EndIf
     C                   EndSr
      *********************************************************************
      * Refresca
      *********************************************************************
     C     Refresca      BegSr
      **
     C     CANAL         Chain     IBPARM01
     C     CANAL         Chain     IBCANA01
      **
     C                   MOVEL     PGM           INIPGM            2
     C     INIPGM        CAT       'RTVFAM'      PGMFEC            8
     C                   CALL      PGMFEC
     C                   PARM                    FECHA            11
     C                   PARM                    MNCAPL            2
     C                   PARM                    MODULO           60
     C                   MoveL     MNCAPL        AplAct            2
      *
     C                   Open      IBSTSS
     C                   Time                    TIMEST
      * Actnalizo status
     C                   Eval      IDCANA = CANAL
     C                   Eval      IDSRV = 'IBDCRSIP'
     C*                  Eval      IDSRV = ZZZPAN
     C     IDSRK         Chain     IBSTSS                             1869
     C                   Eval      STSSTS = PARSTS
     C                   Eval      STSANO = ZZZANO
     C                   Eval      STSMES = ZZZMES
     C                   Eval      STSDIA = ZZZDIA
     C                   Eval      STSHOR = ZZZTIM
     C                   IF        *In18='0'
     C                   IF        *IN69 = '0'
     C                   Update    RCSTSS
     C                   ENDIF
     C                   Else
     C                   Write     RCSTSS
     C                   ENDIF
     C                   Close     IBSTSS
      *
     c     EMPKEY        kList
     c                   kfld                    EMPCOD
     C                   MOVE      '1'           EMPCOD
     C     EMPKEY        CHAIN     DPREGCON
     C                   IF        NOT %Found(DPREGCON)
     C                   Z-ADD     0             DATHOY
     C                   ENDIF
     C     CANAL         CHAIN     IBPSIP01
     C                   EndSr
      *********************************************************************
      * Proceso Principal
      *********************************************************************
     C     PROCE         BegSr
     C                   z-add     0             Clavo1
     C                   CLEAR                   OPER              1
     C                   CLEAR                   DATAOU
     C                   CLEAR                   PXPTOU
      *RECIBE de la web
     C                   MOVEL     DATAIN        DATREC
      *Para log de tramas web-as400
     C                   MOVE      WI_KEYPXP     PXPKEY
     C                   Z-ADD     *YEAR         PXPRXA
     C                   Z-ADD     *MONTH        PXPRXM
     C                   Z-ADD     *DAY          PXPRXD
     C                   TIME                    PXPRXH
     C                   MOVEL     DATAIN        PXPTIN
     C                   Write     rcLTSI
      *Define el modo de Operacion
     C                   SELECT
     C     WI_MODO       WHENEQ    '1'
      *Define el Ciclo
     C                   SELECT
      *debito
     C     WI_CICLO      WHENEQ    01
     C                   EXSR      Debita
      *credito
     C     WI_CICLO      WHENEQ    02
     C                   EXSR      Acredita
      *rechazo o reversa (Credito)
     C     WI_CICLO      WHENEQ    03
     C                   EXSR      Reversa
      *PARAMETRIZACION
     C     WI_CICLO      WHENEQ    04
     C                   EXSR      PARAMETROS
      *bloquea saldo
     C     WI_CICLO      WHENEQ    05
     C                   EXSR      bloquea
      *desbloquea saldo
     C     WI_CICLO      WHENEQ    06
     C                   EXSR      desbloquea
     C                   ENDSL
      *Modo 2 en este requerimiento no se usa, pero se deja para cuando quieran
     C     WI_MODO       WHENEQ    '2'
     C                   EXSR      LLAMAPGM
     C                   ENDSL
      *Actualiza LOG  -Solo si encuentra la llave-
     C                   IF        %Found(IBLTSI)
     C                   Update    rcLTSI
     C                   ENDIF
      *RESPONDE a la web
     C                   CALL      'QSNDDTAQ'
     C                   PARM                    DTQO             10
     C                   PARM                    PARBIQ
     C                   PARM                    IDSLDS
     C                   PARM                    DATAOU         1024
     C                   PARM      IDSLKY        KEYLEN            3 0
     C                   PARM      WI_KEYPXP     TRX_I            16
     C                   EndSr
      *********************************************************************
      * Busca cuenta
      *********************************************************************
     C     BUSEQUIVA     BegSr
      *DEBITO-1
     C     OPER          IFEQ      '1'
     C                   MOVEL     TSTDEB        TRXEQUI          10
     C                   MOVEL     TSTCDB        TRXEQUIC         10
     C                   ENDIF
      *CREDITO-2
     C     OPER          IFEQ      '2'
     C                   MOVEL     TSTCRE        TRXEQUI
     C                   MOVEL     TSTCCR        TRXEQUIC
     C                   ENDIF
      *REVERSA-3
     C     OPER          IFEQ      '3'
      *NO IMPLEMENTADA
     C                   ENDIF
      *BLOQUEO-4
     C     OPER          IFEQ      '4'
     C                   MOVEL     TSTBLQ        TRXEQUI
     C                   ENDIF
      *DESBLOQ-5
     C     OPER          IFEQ      '5'
     C                   MOVEL     TSTDBL        TRXEQUI
     C                   ENDIF
     C                   EndSr
      *********************************************************************
      * DEBITO
      *********************************************************************
     C     Debita        BegSr
      *
     c                   MOVEL     WI_TRAMADET   WI_TRAMADETBK  1024
      *
     C                   MOVEL     WI_TRAMADET   TRADET1
     c                   clear                   WI_TRAMADET
     c                   MOVEL     DI1_IDBXI     WI_TRAMADET
     C                   EXSR      DESBLOQUEA
     c                   clear                   WI_TRAMADET
     c                   MOVEL     WI_TRAMADETBK WI_TRAMADET
     C     CLAVO1        IFEQ      0
     C                   MOVEL     TSTDEB        TRXEQUI          10
     C                   MOVEL     TSTCDB        TRXEQUIC         10
     C                   MOVEL     TSTDBL        TRXEQUID         10
     C                   CLEAR                   DEBITOUT
      *Asigna trama detalle a trama debito
     C                   MOVE      '1'           OPER              1
     C                   MOVE      'D'           OPERCORE          1
     C                   MOVEL     WI_TRAMADET   TRADET1
      *Busca la transferencia
     C                   MOVE      'E'           TIPOTR
     C     BXITKEY       CHAIN     IBTSIP00
     C                   IF        %FOUND(IBTSIP00)
     C                   MOVEL     DI1_CUENTA    CTA25
     C                   MOVE      DI1_MONEDA    MONEDH            3
     C                   Z-ADD     TSMONT        D3               12 2
     C                   Z-ADD     00            D4               12 2
     c                   exsr      armobsdeb
     C                   MOVEL     textodeb      Observacion      40
      *Asigna IDS a Archivo journal
     C                   MOVE      CLDOC         PXPCLI
     C                   MOVE      WI_KEYPXP     PXPKEY
     C                   Z-ADD     WI_FECHAA     PXPAZO
     C                   Z-ADD     WI_FECHAM     PXPMES
     C                   Z-ADD     WI_FECHAD     PXPDIA
     C                   Z-ADD     WI_HORA       PXPHOR
     C                   MOVEL     OPER          PXPTIP
     C                   MOVEL     0             PXPREF
     C                   MOVEL     CTA25         PXPCTA
     C                   Z-ADD     0             PXPTCT
     C                   Z-ADD     D3            PXPMNT
     C                   MOVE      MONEDH        PXPMND
     C                   Z-ADD     0             PXPCRR
     C                   MOVEL     *BLANKS       PXPDRR
     C                   Z-ADD     0             PXPAUT
     C                   Z-ADD     0             PXPSEQ
     C                   Z-ADD     1             PXPCOR
     C                   WRITE     RCJTSI
     C                   ELSE
     C                   z-add     224           clavo1
     c                   ENDIF
      *
     c                   IF        CLAVO1 = 0
     C                   EXSR      ENVIA
     c                   endif
      *
     C                   Z-ADD     CLAVO1        DO1_CERR
     C     CLAVO1        IFEQ      0
     C                   MOVE      *BLANKS       DO1_DERR
     C                   MOVE      NOAUTO        DO1_NAUTOR
     C                   MOVEL     'O'           TSSTAT
     C                   Z-ADD     TSMONT        TSMOOP
      *Envia el debito al total operado mas adelante se suman las comisiones
     C                   Z-ADD     TSmont        TSTOOP
      *Datos para nota de debito en estado de cuenta
     C                   Z-ADD     AZOC4         DCA�AC
     C                   Z-ADD     MESC          DCMEAC
     C                   Z-ADD     DIAC          DCDIAC
     C                   MOVEL     MONCOD        MOCODE
     C                   Z-ADD     noauto        dcrefnum
     C                   Z-ADD     noauto        MVSEQ
     C                   ELSE
     C                   MOVE      'DP'          MEAPLI
     C                   Z-ADD     DO1_CERR      MECODE
     C                   MOVE      '000000'      DO1_NAUTOR
     C     IBERKEY       CHAIN     IBMERR01
     C                   IF        %Found(IBMERR01)
     c                   movel     MEDESC        DO1_DERR
     C                   ELSE
     c                   move      *BLanks       DO1_DERR
     C                   Endif
     C                   MOVEL     'E'           TSSTAT
     C                   Z-ADD     clavo1        tscore
     C                   ENDIF

     c     LOGKEYJ       CHAIN     IBJTSI
     C                   IF        %Found(IBJTSI)
     C                   Z-ADD     DO1_CERR      PXPCRR
     C                   MOVEL     DO1_DERR      PXPDRR
     C                   MOVE      DO1_NAUTOR    PXPSEQ
     C                   z-add     D2            IBRBLQ
     C                   Z-ADD     TRXCOD        PXPRXC
     C                   Z-ADD     *YEAR         TSANOP
     C                   Z-ADD     *MONTH        TSMEOP
     C                   Z-ADD     *DAY          TSDIOP
     C                   TIME                    TSHOOP
     C                   UPDATE    RCJTSI
     C                   UPDATE    RCTSIP
     C                   ENDIF
      *Respuesta a la web
     C                   MOVEL     DEBITOUT      DATAOU
      *
     C     LOGKEY        CHAIN     IBLTSI
     C                   IF        %Found(IBLTSI)
     C                   Z-ADD     *YEAR         PXPROA
     C                   Z-ADD     *MONTH        PXPROM
     C                   Z-ADD     *DAY          PXPROD
     C                   TIME                    PXPROH
     C                   MOVEL     DATAOU        PXPTOU
     C                   ENDIF
      **COMISION SI APLICA
     C     CLAVO1        IFEQ      0
     c                   exsr      comideb
     C                   ENDIF
      **
     C                   ENDIF
     C                   EndSr
      *********************************************************************
      * comision
      *********************************************************************
     C     Comideb       BegSr
      *Busca la transferencia
     C                   MOVE      'E'           TSTIPT
     c     orikey        KLIST
     c                   KFLD                    CACODE
     c                   KFLD                    IBIDIB
     c                   KFLD                    TSTIPT
     C     orikey        CHAIN     IBTSIP00
     C                   IF        %FOUND(IBTSIP00)
     C                   IF        TSCOMI > 0 OR TSCMBC > 0
     C                   MOVE      '1'           OPER              1
     C                   MOVE      'D'           OPERCORE          1
     C                   Z-ADD     TSCOMI        D3               12 2
     C                   Z-ADD     TSCMBC        D4               12 2
     C     TSCOMI        ADD       TSCMBC        D5               12 2
     C                   MOVE      *BLANKS       Observacion      40
      *Asigna IDS a Archivo journal
     c                   CLEAR                   TRXEQUI
     c                   movel     TRXEQUIC      TRXEQUI

     C                   MOVEL     CLCCLI        PXPCLI
     C                   MOVE      WI_KEYPXP     PXPKEY
     C                   Z-ADD     WI_FECHAA     PXPAZO
     C                   Z-ADD     WI_FECHAM     PXPMES
     C                   Z-ADD     WI_FECHAD     PXPDIA
     C                   Z-ADD     WI_HORA       PXPHOR
     C                   MOVEL     OPER          PXPTIP
     C                   MOVEL     0             PXPREF
     C                   MOVEL     CTA25         PXPCTA
     C                   Z-ADD     0             PXPTCT
     C                   Z-ADD     D3            PXPMNT
     C                   MOVE      MONEDH        PXPMND
     C                   Z-ADD     0             PXPCRR
     C                   MOVEL     *BLANKS       PXPDRR
     C                   Z-ADD     0             PXPAUT
     C                   Z-ADD     0             PXPSEQ
     C                   ADD       1             PXPCOR
     C                   WRITE     RCJTSI
      *
     c                   IF        CLAVO1 = 0
     C                   EXSR      ENVIA
     c                   endif
      *
     C                   Z-ADD     CLAVO1        DO1_CERR
     C     CLAVO1        IFEQ      0
     C                   MOVE      *BLANKS       DO1_DERR
     C                   MOVE      NOAUTO        DO1_NAUTOR
     C                   Z-ADD     TSCMBC        TSCOBC
     C                   Z-ADD     TSCOMI        TSCMOP
     C                   add       TSCOBC        TSTOOP
     C                   add       TSCMOP        TSTOOP
     C                   ELSE
     C                   Z-ADD     0             TSCOBC
     C                   Z-ADD     0             TSCMOP
     C                   MOVE      'DP'          MEAPLI
     C                   Z-ADD     DO1_CERR      MECODE
     C                   MOVE      '000000'      DO1_NAUTOR
     C     IBERKEY       CHAIN     IBMERR01
     C                   IF        %Found(IBMERR01)
     c                   movel     MEDESC        DO1_DERR
     C                   ELSE
     c                   move      *BLanks       DO1_DERR
     C                   Endif
     C                   ENDIF
     C                   UPDATE    RCTSIP

     c     LOGKEYJ       CHAIN     IBJTSI
     C                   IF        %Found(IBJTSI)
     C                   Z-ADD     DO1_CERR      PXPCRR
     C                   MOVEL     DO1_DERR      PXPDRR
     C                   MOVE      DO1_NAUTOR    PXPSEQ
     C                   z-add     D2            IBRBLQ
     C                   Z-ADD     TRXCOD        PXPRXC
     C                   UPDATE    RCJTSI
     C                   ENDIF
      *Busca la transferencia
     C                   ENDIF
     C                   ENDIF
     C                   EndSr
      *********************************************************************
      * CREDITO
      *********************************************************************
     C     Acredita      BegSr
     C                   EndSr
      *********************************************************************
      * comision
      *********************************************************************
     C     Comicre       BegSr

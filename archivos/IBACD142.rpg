      *********************************************************************
      * DEVUELVE PARAMETROS
      *********************************************************************
     C     Parametros    BegSr
     C                   CLEAR                   PARAMOUT
      *Asigna trama detalle a trama debito
     C                   MOVEL     WI_TRAMADET   TRADET4
     C                   MOVEL     DI4_CUENTA    CTA25
      *PARA BUSCAR LA CUENTA EN EL ARCHIVO DE EXCENTAS CLIENTE DPCTAS
     C     CTAKEY        Chain     DPCTAS01
     C                   IF        %Found(DPCTAS01)
     C     CLIKEY        CHAIN     CLMCTE01
     c                   IF        %FOUND(CLMCTE01)
     C                   MOVE      CLDOC         DO4_CIF
     C                   MOVEL     CLNOMB        DO4_NOMBRE
     C                   MOVE      CLTID@        DO4_TIPOD
     C                   MOVE      CLNUID        DO4_NUMDO
     C                   ENDIF
     C                   ENDIF
      *
     C                   Z-ADD     0             DO4_CERR
     C                   Z-ADD     0             DO4_NAUTOR
     C                   MOVE      *BLANKS       DO4_DERR

     c     LOGKEYJ       CHAIN     IBJTSI
     C                   IF        %Found(IBJTSI)
     C                   Z-ADD     DO4_CERR      PXPCRR
     C                   MOVEL     DO4_DERR      PXPDRR
     C                   Z-ADD     0             PXPAUT
     C                   Z-ADD     0             PXPSEQ
     C                   Z-ADD     0             PXPRXC
     C                   UPDATE    RCJTSI
     C                   ENDIF
      *Respuesta a la web
     C                   MOVEL     PARAMOUT      DATAOU
      *
     C     LOGKEY        CHAIN     IBLTSI
     C                   IF        %Found(IBLTSI)
     C                   Z-ADD     *YEAR         PXPROA
     C                   Z-ADD     *MONTH        PXPROM
     C                   Z-ADD     *DAY          PXPROD
     C                   TIME                    PXPROH
     C                   MOVEL     PARAMOUT      PXPTOU
     C                   ENDIF
     C                   EndSr
      **********************************************************************
      * ENVIA A DEPOSITOS
      **********************************************************************
     C     ENVIA         BEGSR
      *Validaciones
      *Esto es generico para Debito-Credito
     c     CTAKEY        Chain     DPCTAS01
     C                   IF        %Found(DPCTAS01)
      *Guardar el codigo de cliente en Cred-Rever
     C                   CLEAR                   CLTDEP           18
     C                   MOVE      CLDOC         CLTDEP
      *
     C     CANAL         CHAIN     IBCAJE01
     c                   Z-ADD     IBCAGB        MNAGE             3 0
     C                   Z-ADD     IBCCAJ        OPERAD            5 0
     C
     C     MONCOD        IFEQ      monedh
     c                   exsr      Bustrx
     C                   Z-Add     TrxCod        TrxcodObs
     C                   Z-ADD     MOTCOD        CODMOT            3 0
     c     OPERCORE      CHAIN     DPTRXCOR                           1969
     c     *in69         Doweq     *ON
     c     OPERCORE      CHAIN     DPTRXCOR                           1969
     c                   Enddo
 NEW C                   ADD       1             CORCOR
 NEW C                   UPDATE    RCTRXCOR
     C                   EXSR      ACT
     C                   ELSE
     c                   Z-ADD     55            CLAVO1
     C                   ENDIF
     C                   ELSE
     c                   Z-ADD     20            CLAVO1
     C                   CLEAR                   CLTDEP           18
     C                   ENDIF
     C                   EndSr
      **********************************************************************
      * ACTUALIZA
      **********************************************************************
     C     ACT           BEGSR
      * Solo para el modo Desbloqueo
     C     OPER          IFEQ      '5'
     C*                  z-add     IBRBLQ        CORCOR
     C                   z-add     MVSEQ         CORCOR
     C                   ENDIF
      * Solo para el modo Desbloqueo
      *D4 lleva el valor, si es menor o igual a 0 no debe hacerse
     C                   If        D3 > 0 or D5 > 0
     C     CTA           DIV       100           D1               12 2
     C     CORCOR        DIV       100           D2               12 2
     C                   Z-ADD     DIADP         DIAC
     C                   Z-ADD     MESDP         MESC
     C                   Z-ADD     AZODP         AZOC
     C                   Z-ADD     AZODP4        AZOC4             4 0
     C                   TIME                    HORAA
      *
      *  Arregla campo de observaciones para enviar en la transacci�n ..
     C                   CLEAR                   RESTO$
     C     OBSERVACION   IFNE      *BLANKS
     C                   EXSR      RUT79
     C                   ENDIF
      *Ejecuta transaccion
     C                   CALL      'DPACDPLIB'
     C                   PARM      'N'           REVSN             1
     C                   PARM                    TRXCOD            4 0
     C                   PARM                    OPERAD            5 0
     C                   PARM      FECHADP       AFECH             6 0
     C                   PARM                    HORAA             6 0
     C                   PARM                    MNAGE             3 0
     C                   PARM                    D1               12 2
     C                   PARM                    D2               12 2
     C                   PARM                    D3               12 2
     C                   PARM                    D4               12 2
     C                   PARM                    D5               12 2
     C                   PARM                    D6               12 2
     C                   PARM                    D7               12 2
     C                   PARM                    D8               12 2
     C                   PARM                    D9               12 2
     C                   PARM                    D0               12 2
     C                   PARM                    OPERO             1
     C                   PARM      0             CLAVO1            3 0
     C                   PARM      0             NOAUTO            6 0
     C                   PARM                    RESTO$          512
     C                   Else
     C                   z-add     53            Clavo1
     C                   EndIf
      *
     C                   ENDSR
      *- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - *
      * Rutina para buscar el c�digo de transacci�n de D�bito
      *- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - *
     C     BusTrx        Begsr
      *ACA SE USA LA TRANSACCION EQUIVALENTE
     C                   Eval      TXU(1) = TRXEQUI
     C                   Z-add     TIPPRO        TIPPRT            2 0
     C                   Movel     MONCOD        MONCOT            3
     C                   CALL      'DPRTVTXE'
     C                   PARM                    TXU
     C                   PARM                    MON
     C                   PARM                    TXE
     C                   PARM                    MTE
     C                   PARM      3             CTR               2 0
      * TRANSACCION
     C                   MOVEL     TXU(1)        FNDTXT           11
     C                   MOVE      MONCOT        FNDTXT
     C                   MOVEL     FNDTXT        FNDTXE           13
     C                   MOVE      TIPPRT        FNDTXE
      *
     C                   Z-ADD     1             IE@               2 0
     C     FNDTXE        LOOKUP    MON(IE@)                               19
     C     *IN19         IFEQ      *OFF
     C                   MOVEL     FNDTXE        FNDTSP           13
     C                   MOVE      '00'          FNDTSP
     C     FNDTSP        LOOKUP    MON(IE@)                               19
     C     *IN19         IFEQ      *OFF
     C                   MOVE      FNDTXE        FNDTM1            5
     C                   MOVEL     '   '         FNDTM1
     C                   MOVEL     FNDTXE        FNDTSM           13
     C                   MOVE      FNDTM1        FNDTSM
     C     FNDTSM        LOOKUP    MON(IE@)                               19
     C     *IN19         IFEQ      *OFF
     C                   MOVE      '00'          FNDTSM
     C     FNDTSM        LOOKUP    MON(IE@)                               19
     C                   ENDIF
     C                   ENDIF
     C                   ENDIF
     C     *IN19         IFEQ      *ON
     C                   Z-ADD     TXE(IE@)      TXE@@@            4 0
     C                   Z-ADD     MTE(IE@)      MTV@@@            3 0
     C                   ELSE
     C                   Z-ADD     0             TXE@@@
     C                   Z-ADD     0             MTV@@@
     C                   ENDIF
      *
     C                   Z-ADD     TXE@@@        TRXCOD            4 0
     C                   Z-ADD     MTV@@@        MOTCOD            3 0
      *
     C                   EndSr
      *********************************************************************
      * LLAMA PROGRAMA
      *********************************************************************
     C     Llamapgm      BegSr
     C                   MOVE      WI_TRAMADET   TRAMASEND      1024
      * Genera XML y recupera nombre de Archivo
      * Variable TRAMASEND envia el formato que usa el xml
     C                   CALL      'IBACD002'                           13
     C                   PARM                    CANAL
     C                   PARM                    SERVICIO         10
     C                   Parm                    Cliente          20
     C                   Parm      TRAMASEND     Trama          2048
     C                   Parm                    Key16            85
     C                   Parm                    ErrServ           1
     C                   Parm      *ZEROS        CodErrServ        3 0
     C                   Parm                    TramaHed       2048
     C                   Parm      WI_IDEJEC     Programa         10
      * Variable TRAMA regresa con el correlativo de XML
     C     CodErrServ    IFEQ      0
     c                   z-add     0             WO2_CERR
     c                   move      *BLanks       WO2_DERR
     c                   movel     Trama         WO2_NARC
     C                   ELSE
     c                   z-add     CodErrServ    WO2_CERR
     C                   MOVE      'IB'          MEAPLI
     C                   Z-ADD     WO2_CERR      MECODE
     C     IBERKEY       CHAIN     IBMERR01
     C                   IF        %Found(IBMERR01)
     c                   movel     MEDESC        WO2_DERR
     C                   ELSE
     c                   move      *BLanks       WO2_DERR
     C                   Endif
     c                   move      *Blanks       WO2_NARC
     C                   ENDIF
     C                   MOVEL     WOMODO2       DATAOU
     c     LOGKEY        CHAIN     IBLTSI
     C                   IF        %Found(IBLTSI)
     C                   Z-ADD     *YEAR         PXPROA
     C                   Z-ADD     *MONTH        PXPROM
     C                   Z-ADD     *DAY          PXPROD
     C                   TIME                    PXPROH
     C                   MOVEL     WOMODO2       PXPTOU
     C                   ENDIF
     C                   EndSr
      *- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - *
      *      Busca posici�n de las observaciones en la transacci�n             *
      *- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - *
     C     RUT79         BEGSR
      *
     C     TbOKey        KLIST
     C                   KFLD                    TbOKF1           10
     C                   KFLD                    TbOKF2            1
     C                   KFLD                    TbOKF3            3 0
      *
     C                   Eval      TbOKF1 = 'DPACDPLIB'
     C                   Eval      TbOKF2 = 'O'
      * Busca la posici�n de la trama donde viene el texto de Observaciones
      * (un c�digo de descriptor, debe encontrarse en el archivo DPTB13)

     C     TRXCODObs     CHAIN     DPTRX01                            19
     C                   MoveA     *Blanks       $ValA

     C                   Z-Add     0             $PObs
     C                   Eval      $IDO = 1
     C                   Dow       $IDO <= 10 and $PObs = 0
     C                   Eval      TbOKF3 = ND($IDO)
     C     TbOKey        Chain     DpTb13
     C                   If        %Found(DpTb13)
     C                   Eval      $PObs = $IDO
     C                   Eval      $ValA($PObs) = Observacion
     C                   MoveA     $ValA         DatosAlfa       400
     C                   Movel     DatosAlfa     Resto$
     C                   End
     C                   Eval      $IDO = $IDO + 1
     C                   EndDo
      *
     C                   ENDSR
      *********************************************************************
      * Bloqueo
      *********************************************************************
     C     Bloquea       BegSr
     C                   CLEAR                   BLOQUOUT
      *EQUIVALENTE
     C                   MOVEL     *blanks       TRXEQUI
     C                   MOVEL     TSTBLQ        TRXEQUI
      *Asigna trama detalle a trama debito
     C                   MOVE      '4'           OPER              1
     C                   MOVE      'D'           OPERCORE          1
     C                   MOVEL     WI_TRAMADET   TRADET5
      *Busca la transferencia
     C                   MOVE      'E'           TIPOTR
     C     BXITKE2       CHAIN     IBTSIP07
     C                   IF        %FOUND(IBTSIP07)
     C                   MOVEL     DI5_CTA25     CTA25
     C                   MOVE      DI5_MONEDA    MONEDH            3
     C                   Z-ADD     DI5_MONTO     D3               12 2
     C                   Z-ADD     00            D4               12 2
     C                   MOVE      *BLANKS       Observacion      40
      *Asigna IDS a Archivo journal
     C                   MOVE      CLDOC         PXPCLI
     C                   MOVE      WI_KEYPXP     PXPKEY
     C                   Z-ADD     WI_FECHAA     PXPAZO
     C                   Z-ADD     WI_FECHAM     PXPMES
     C                   Z-ADD     WI_FECHAD     PXPDIA
     C                   Z-ADD     WI_HORA       PXPHOR
     C                   MOVEL     OPER          PXPTIP
     C                   MOVEL     0             PXPREF
     C                   MOVEL     CTA25         PXPCTA
     C                   Z-ADD     0             PXPTCT
     C                   Z-ADD     D3            PXPMNT
     C                   MOVE      MONEDH        PXPMND
     C                   Z-ADD     0             PXPCRR
     C                   MOVEL     *BLANKS       PXPDRR
     C                   Z-ADD     0             PXPAUT
     C                   Z-ADD     0             PXPSEQ
     C                   Z-ADD     1             PXPCOR
     C                   WRITE     RCJTSI
      *
     C                   ELSE
     C                   z-add     224           clavo1
     c                   ENDIF
     c                   IF        CLAVO1 = 0
     C                   EXSR      ENVIA
     c                   endif
      *
     C                   Z-ADD     CLAVO1        DO5_CERR
     C     CLAVO1        IFEQ      0
     C                   MOVE      *BLANKS       DO5_DERR
     C                   MOVE      NOAUTO        DO5_NAUTOR
     C                   ELSE
     C                   MOVE      'DP'          MEAPLI
     C                   Z-ADD     DO5_CERR      MECODE
     C                   MOVE      '000000'      DO5_NAUTOR
     C     IBERKEY       CHAIN     IBMERR01
     C                   IF        %Found(IBMERR01)
     c                   movel     MEDESC        DO5_DERR
     C                   ELSE
     c                   move      *BLanks       DO5_DERR
     C                   Endif
     C                   Z-ADD     clavo1        tscore
     C                   MOVEL     'E'           TSSTAT
     C                   ENDIF

     c     LOGKEYJ       CHAIN     IBJTSI
     C                   IF        %Found(IBJTSI)
     C                   Z-ADD     DO5_CERR      PXPCRR
     C                   MOVEL     DO5_DERR      PXPDRR
     C                   MOVE      DO5_NAUTOR    PXPSEQ
     C                   z-add     D2            IBRBLQ
     C                   Z-ADD     TRXCOD        PXPRXC
     c                   z-add     pxpseq        tsrefe
     C                   UPDATE    RCJTSI
      *Datos para nota de debito en estado de cuenta
     C                   Z-ADD     AZOC4         DCA�AC
     C                   Z-ADD     MESC          DCMEAC
     C                   Z-ADD     DIAC          DCDIAC
     C                   MOVEL     MONCOD        MOCODE
     C                   Z-ADD     noauto        dcrefnum
     C                   Z-ADD     noauto        MVSEQ
     C                   UPDATE    RCTSIP07
     C                   ENDIF
      *Respuesta a la web
     C                   MOVEL     BLOQUOUT      DATAOU
      *
     C     LOGKEY        CHAIN     IBLTSI
     C                   IF        %Found(IBLTSI)
     C                   Z-ADD     *YEAR         PXPROA
     C                   Z-ADD     *MONTH        PXPROM
     C                   Z-ADD     *DAY          PXPROD
     C                   TIME                    PXPROH
     C                   MOVEL     DATAOU        PXPTOU
     C                   ENDIF
     C                   EndSr
      *********************************************************************
      * Desbloquea
      *********************************************************************
     C     Desbloquea    BegSr
     C                   CLEAR                   DESBLOUT
      *EQUIVALENTE
     C                   MOVEL     *blanks       TRXEQUI
     C                   MOVEL     TSTDBL        TRXEQUI
      *Asigna trama detalle a trama debito
     C                   MOVE      '5'           OPER              1
     C                   MOVE      'C'           OPERCORE          1
     C                   MOVEL     WI_TRAMADET   TRADET6
     C                   MOVE      'E'           TSTIPT
     C     DESBKEY       CHAIN(N)  IBTSIP00
     C                   IF        %FOUND(IBTSIP00)
     c
     C                   MOVEL     CTNCTA        CTA25
     C                   MOVE      MONCOD        MONEDH            3
     C                   Z-ADD     TSTOTT        D3               12 2
     C                   Z-ADD     00            D4               12 2
     C                   MOVE      *BLANKS       Observacion      40
      *Asigna IDS a Archivo journal
     C                   MOVE      CLDOC         PXPCLI
     C                   MOVE      WI_KEYPXP     PXPKEY
     C                   Z-ADD     WI_FECHAA     PXPAZO
     C                   Z-ADD     WI_FECHAM     PXPMES
     C                   Z-ADD     WI_FECHAD     PXPDIA
     C                   Z-ADD     WI_HORA       PXPHOR
     C                   MOVEL     OPER          PXPTIP
     C                   MOVEL     0             PXPREF
     C                   MOVEL     CTA25         PXPCTA
     C                   Z-ADD     0             PXPTCT
     C                   Z-ADD     D3            PXPMNT
     C                   MOVE      MONEDH        PXPMND
     C                   Z-ADD     0             PXPCRR
     C                   MOVEL     *BLANKS       PXPDRR
     C                   Z-ADD     0             PXPAUT
     C                   Z-ADD     0             PXPSEQ
     C                   Z-ADD     1             PXPCOR
     C                   WRITE     RCJTSI
     C                   ELSE
     C                   z-add     224           clavo1
     c                   ENDIF
     c                   IF        CLAVO1 = 0
     C                   EXSR      ENVIA
     c                   endif
      *
     C                   Z-ADD     CLAVO1        DO6_CERR
     C     CLAVO1        IFEQ      0
     C                   MOVE      *BLANKS       DO6_DERR
     C                   MOVE      NOAUTO        DO6_NAUTOR
     C                   ELSE
     C                   MOVE      'DP'          MEAPLI
     C                   Z-ADD     DO6_CERR      MECODE
     C                   MOVE      '000000'      DO5_NAUTOR
     C     IBERKEY       CHAIN     IBMERR01
     C                   IF        %Found(IBMERR01)
     c                   movel     MEDESC        DO6_DERR
     C                   ELSE
     c                   move      *BLanks       DO6_DERR
     C                   Endif
     C     DESBKEY       CHAIN     IBTSIP00
     C                   IF        %FOUND(IBTSIP00)
     C                   MOVEL     'E'           TSSTAT
     C                   Z-ADD     clavo1        tscore
     C                   Z-ADD     *YEAR         TSANOP
     C                   Z-ADD     *MONTH        TSMEOP
     C                   Z-ADD     *DAY          TSDIOP
     C                   TIME                    TSHOOP
     C                   UPDATE    RCTSIP
     C                   ENDIF
     C                   ENDIF

     c     LOGKEYJ       CHAIN     IBJTSI
     C                   IF        %Found(IBJTSI)
     C                   Z-ADD     DO6_CERR      PXPCRR
     C                   MOVEL     DO6_DERR      PXPDRR
     C                   MOVE      DO6_NAUTOR    PXPSEQ
     C                   z-add     D2            IBRBLQ
     C                   Z-ADD     TRXCOD        PXPRXC
     C                   UPDATE    RCJTSI
     C                   ENDIF
      *Respuesta a la web
     C                   MOVEL     DESBLOUT      DATAOU
      *
     C     LOGKEY        CHAIN     IBLTSI
     C                   IF        %Found(IBLTSI)
     C                   Z-ADD     *YEAR         PXPROA
     C                   Z-ADD     *MONTH        PXPROM
     C                   Z-ADD     *DAY          PXPROD
     C                   TIME                    PXPROH
     C                   MOVEL     DATAOU        PXPTOU
     C                   ENDIF
     C                   EndSr
      *********************************************************************
      *********************************************************************
     C     ARMOBSDEB     BegSr
     C                   CLEAR                   TEXTODEB         40
     C     BKEY          KLIST
     C                   KFLD                    CACODE
     C                   KFLD                    TSCOPA
     C                   KFLD                    TSCOBP
     C     BKEY          CHAIN     IBBANP01
     C     TSTIBE        IFEQ      'I'
     C                   EVAL      TEXTODEB=%TRIM(TSCOPA)+'/'+%TRIM(TSDEBP)+'/'+
     C                                      %TRIM(TSNOM1)+' '+%TRIM(TSNOM2)+' '+
     C                                      %TRIM(TSAPE1)+' '+%TRIM(TSAPE2)
     C                   ELSE
     C                   EVAL      TEXTODEB=%TRIM(TSCOPA)+'/'+%TRIM(TSDEBP)+'/'+
     C                                      %TRIM(TSNOME)
     C                   ENDIF
     C                   EndSr
